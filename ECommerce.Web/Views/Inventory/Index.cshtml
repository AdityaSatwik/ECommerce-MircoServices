@model IEnumerable<ECommerce.Web.Models.InventoryItemViewModel>
@{ ViewData["Title"] = "Legacy Inventory"; }

<h2 class="mb-4">Legacy Inventory</h2>

<div class="card p-4">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Product ID</th>
                <th>Stock Level</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.ProductId</td>
                    <td>
                        <form asp-action="Update" method="post" class="d-flex gap-2 align-items-center">
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="number" name="quantity" value="@item.Quantity" class="form-control form-control-sm" style="width: 80px;" />
                            <button type="submit" class="btn btn-sm btn-primary">Update</button>
                            <span class="badge @(item.Quantity < 10 ? "bg-danger" : "bg-success")">
                                Stock: @item.Quantity
                            </span>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
